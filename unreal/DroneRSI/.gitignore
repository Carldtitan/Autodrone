# The project depends on checked-in AirSim/Cesium plugin source.
# Generated plugin Binaries/ and Intermediate/ are ignored by the root .gitignore.
# Don't add packaged binaries
Packaged/

# don't check-in generated files
*.sln
*_BuiltData.uasset
/.kdev/
/*.kdev4
/*.pro
/*.workspace
/*CodeCompletionFolders.txt
/*CodeLitePreProcessor.txt
/*.pri
/CMakeLists.txt
/Makefile

# Keep the project descriptor in this repository.

# avoid checking in MacOS XCode assets
*.xcworkspace
